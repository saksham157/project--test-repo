pipeline {
    agent {
        kubernetes {
            label 'kaniko-agent'
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:latest
    command:
    - cat
    tty: true

  - name: python
    image: python:3.11
    command:
    - cat
    tty: true
"""
        }
    }

    environment {
        IMAGE = "saksham8000/project-test-repo:${BUILD_NUMBER}"
        GITOPS_REPO = "https://github.com/saksham157/ai-self-healing-gitops.git"
    }

    stages {

        stage('Test App') {
            steps {
                container('python') {
                    sh '''
                    pip install flask
                    python app.py &
                    sleep 3
                    curl localhost:5000
                    '''
                }
            }
        }

        stage('Build & Push Image (Kaniko)') {
            steps {
                container('kaniko') {
                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'USER',
                        passwordVariable: 'PASS'
                    )]) {
                        sh '''
                        mkdir -p /kaniko/.docker
                        echo "{\"auths\":{\"https://index.docker.io/v1/\":{\"username\":\"$USER\",\"password\":\"$PASS\"}}}" > /kaniko/.docker/config.json

                        /kaniko/executor \
                          --context `pwd` \
                          --dockerfile Dockerfile \
                          --destination $IMAGE
                        '''
                    }
                }
            }
        }

        stage('Update GitOps Repo') {
            steps {
                container('python') {
                    sh '''
                    git clone $GITOPS_REPO
                    cd ai-self-healing-gitops/prod

                    sed -i "s|image: .*|image: $IMAGE|" deployment.yaml

                    git config user.email "jenkins@example.com"
                    git config user.name "jenkins"

                    git commit -am "update image to $IMAGE"
                    git push
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "✅ Image built + pushed + GitOps updated → ArgoCD will deploy"
        }
        failure {
            echo "❌ Pipeline failed"
        }
    }
}